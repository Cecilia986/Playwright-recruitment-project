{
  "name": "playwright-recruitment-project",
  "version": "1.0.0",
  "description": "Playwright automation framework for recruitment showcasing UI and API testing capabilities",
  "main": "index.js",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "test:qa": "cross-env ENV=qa npx playwright test",
    "test:dev": "cross-env ENV=dev npx playwright test",
    "test:serial:ci": "cross-env ENV=qa npx playwright test --project=Chromium --workers=1",
    "test:chromium": "cross-env ENV=qa npx playwright test --project=Chromium",
    "test:login": "cross-env ENV=qa npx playwright test tests/login/loginTest.spec.ts --project=Chromium",
    "test:api": "cross-env ENV=qa npx playwright test tests/api/",
    "test:db": "cross-env ENV=qa npx playwright test DB.test.ts --project=DB",
    "test:record": "npx playwright codegen",
    "allureReport": "allure generate allure-results --clean",
    "docker:build": "docker build --no-cache-t playwright-tests .",
    "docker:test": "docker run --rm -v \"/$(pwd)/test-results:/app/test-results/\" -v \"/$(pwd)/html-report:/app/html-report/\" -e ENV=qa playwright-tests --workers=1",

    "docker:test:dev": "docker run --rm -v \"/$(pwd)/test-results:/app/test-results/\" -v \"/$(pwd)/html-report:/app/html-report/\" -e ENV=dev playwright-tests --workers=1"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Cecilia986",
  "license": "MIT",
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "allure-playwright": "^3.4.5",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "exceljs": "^4.4.0",
    "lighthouse": "^9.6.8",
    "ortoni-report": "^4.0.5",
    "pdfjs-dist-es5": "^2.13.216",
    "pg": "^8.18.0",
    "typescript": "^5.9.3",
    "winston": "^3.19.0"
  }
}
